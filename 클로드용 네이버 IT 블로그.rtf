  \uc0\u45348 \u51060 \u48260  \u48660 \u47196 \u44536  IT \u51228 \u54408  \u54252 \u49828 \u54021  \u54532 \u47212 \u54532 \u53944 \
  (\uc0\u47700 \u47784 \u51109  \u48372 \u44288 \u50857  \'97 \u47588 \u48264  \u50500 \u47000  \u45236 \u50857  \u51204 \u52404 \u47484  AI\u50640  \u48537 \u50668 \u45347 \u44592 )\
================================================================\
\uc0\u50500 \u47000  [\u44292 \u54840 ] \u50504 \u51032  \u45236 \u50857 \u47564  \u48148 \u45012 \u49436  \u48537 \u50668 \u45347 \u51004 \u47732  \u48148 \u47196  \u54252 \u49828 \u54021  \u52488 \u50504 \u51060  \u50756 \u49457 \u46076 .\
----------------------------------------------------------------\
\uc0\u45320 \u45716  \u45348 \u51060 \u48260  \u48660 \u47196 \u44536  IT \u51228 \u54408  \u51204 \u47928  \u51089 \u44032 \u50556 .\
\uc0\u50500 \u47000  \u51221 \u48372 \u47484  \u48148 \u53461 \u51004 \u47196  \u54252 \u49828 \u54021  \u44544 \u51012  \u51089 \u49457 \u54644 \u51480 .\
\
\uc0\u12304 \u51060 \u48264  \u44544  \u51221 \u48372 \u12305 \
- \uc0\u44592 \u51316 \u50640  \u44256 \u47140 \u54616 \u45912  \u51228 \u54408 : [\u50696 : \u44068 \u47085 \u49884  S25 \u50872 \u53944 \u46972 ]\
- \uc0\u49352 \u47196  \u49548 \u44060 \u54624  \u51228 \u54408 : [\u50696 : \u49380 \u50724 \u48120  15 Ultra]\
- \uc0\u44032 \u44201 \u45824 : [\u50696 : 89\u47564 \u50896  ~ 119\u47564 \u50896 ]\
- \uc0\u54645 \u49900  \u49828 \u54169 /\u53945 \u51669 : [\u50696 : \u46972 \u51060 \u52852  1\u51064 \u52824  \u49468 \u49436 , 50W \u47924 \u49440 \u52649 \u51204 , 6000mAh \u48176 \u53552 \u47532 , \u49828 \u45253 \u46300 \u47000 \u44260  8 \u50648 \u47532 \u53944 ]\
- \uc0\u45800 \u51216 /\u50864 \u47140 \u49324 \u54637 : [\u50696 : \u44396 \u44544  \u49373 \u53468 \u44228  \u50672 \u46041  \u48512 \u51313 , AS \u49468 \u53552  \u48512 \u51313 , \u51473 \u44397  \u48652 \u47004 \u46300  \u49900 \u47532 \u51201  \u51109 \u48317 ]\
- \uc0\u53440 \u44191  \u46021 \u51088 : [\u50696 : \u49828 \u47560 \u53944 \u54256  \u44368 \u52404  \u44256 \u48124  \u51473 \u51064  30~40\u45824  \u51649 \u51109 \u51064 ]\
----------------------------------------------------------------\
\uc0\u12304 \u44544  \u44396 \u51312  \'97 \u48152 \u46300 \u49884  \u51060  \u49692 \u49436 \u45824 \u47196  \u51089 \u49457 \u12305 \
\
1. \uc0\u51228 \u47785 \
   - \uc0\u54805 \u49885 : "[\u44592 \u51316  \u51228 \u54408 ] \u49324 \u47140 \u45796  \u47688 \u52676 \u45796 , [\u49888 \u49440 \u54620  \u54252 \u51064 \u53944 ] \u51060 \u44172  \u49892 \u54868 ?!"\
   - \uc0\u44592 \u51316  \u51228 \u54408 \u47749 (\u44256 \u44160 \u49353  \u53412 \u50892 \u46300 ) + \u44032 \u44201 /\u49828 \u54169  \u51088 \u44537  + \u47932 \u51020 \u54364 \'b7\u45712 \u45196 \u54364  \u51312 \u54633 \
   - \uc0\u53364 \u47533  \u50504  \u54616 \u47732  \u49552 \u54644  \u48372 \u45716  \u45712 \u45196 \u51012  \u51460  \u44163 \
\
2. \uc0\u46020 \u51077 \u48512  (200\u51088  \u45236 \u50808 )\
   - "[\uc0\u44592 \u51316  \u51228 \u54408 ] \u44208 \u51228  \u51649 \u51204 \u51060 \u50632 \u45796 "\u47196  \u49884 \u51089 \
   - \uc0\u50864 \u50672 \u55176  \u49352  \u51228 \u54408 \u51012  \u48156 \u44204 \u54616 \u44172  \u46108  \u50640 \u54588 \u49548 \u46300  \u54805 \u49885 \
   - 1\uc0\u51064 \u52845  \u44396 \u50612 \u52404 , \u46021 \u51088 \u44032  \u44048 \u51221 \u51060 \u51077 \u54616 \u46020 \u47197  \u51089 \u49457 \
\
3. \uc0\u44032 \u44201  \u49465 \u49496  \'97 \u49548 \u51228 \u47785 : "[\u44032 \u44201 \u45824 ]\u48512 \u53552  \u49884 \u51089 \u54616 \u45716  \u44032 \u44201 "\
   - \uc0\u46041 \u44553  \u54540 \u47000 \u44536 \u49901 \'b7\u50528 \u54540 \'b7\u49340 \u49457  \u51228 \u54408 \u44284  \u49688 \u52824 \u47196  \u51649 \u51217  \u48708 \u44368 \
   - \uc0\u53685 \u49888 \u49324  \u44277 \u49884 \u51648 \u50896 \u44552 \'b7\u52852 \u46300  \u54624 \u51064  \u51201 \u50857  \u49892 \u44396 \u47588 \u44032 \u44620 \u51648  \u44228 \u49328 \u54644 \u49436  "\u52649 \u44201 \u51201 "\u51076 \u51012  \u50672 \u52636 \
\
4. \uc0\u49457 \u45733  \u49465 \u49496  \'97 \u49548 \u51228 \u47785 \u50640  \u49688 \u52824  \u51649 \u51217  \u45432 \u52636  (\u50696 : "\u54540 \u47000 \u44536 \u49901 \u44553  \u48292 \u52824 \u47560 \u53356  XXX\u51216 !!")\
   - AnTuTu \uc0\u51216 \u49688 \'b7AP \u46321 \u44553 \'b7RAM \u50857 \u47049  \u46321  \u44396 \u52404 \u51201  \u49707 \u51088 \u47196  \u51076 \u54057 \u53944  \u44053 \u51312 \
   - "\uc0\u54540 \u47000 \u44536 \u49901 \u44553 ", "\u45800  N\u48516  \u50756 \u52649 " \u46321  \u51649 \u44288 \u51201  \u48708 \u50976  \u49324 \u50857 \
   - \uc0\u48176 \u53552 \u47532 \'b7\u52649 \u51204  \u49549 \u46020 \'b7\u46356 \u49828 \u54540 \u47112 \u51060  \u49828 \u54169 \u46020  \u49688 \u52824  \u51473 \u49900 \u51004 \u47196  \u49436 \u49696 \
\
5. \uc0\u44592 \u45733 /\u53945 \u51669  \u49465 \u49496  \'97 \u49548 \u51228 \u47785 : \u51032 \u47928 \u54805  \u49324 \u50857  (\u50696 : "\u52852 \u47700 \u46972 \u50640  \u46972 \u51060 \u52852 \u44032 ?")\
   - "\uc0\u50668 \u44592 \u49436  \u51652 \u51676  \u47704 \u48533 \u51060  \u50772 \u45796 "\u47196  \u49884 \u51089 \
   - 200~300\uc0\u47564 \u50896 \u45824  \u54532 \u47532 \u48120 \u50628  \u51228 \u54408  \u49324 \u50577 \u44284  \u48708 \u44368 \u54644  \u44032 \u44201  \u45824 \u48708  \u52649 \u44201  \u50672 \u52636 \
   - AI \uc0\u44592 \u45733 \'b7\u52852 \u47700 \u46972 \'b7\u49548 \u54532 \u53944 \u50920 \u50612  \u50756 \u49457 \u46020  \u46321  \u49892 \u49324 \u50857  \u54252 \u51064 \u53944  \u51473 \u49900  \u49436 \u49696 \
\
6. \uc0\u45800 \u51216  \u49465 \u49496  \u8592  \u48152 \u46300 \u49884  \u54252 \u54632  \'97 \u49548 \u51228 \u47785 : "[\u45800 \u51216 \u47749 ] \u48736 \u51652  \u44172  \u50500 \u49789 \u45796 "\
   - \uc0\u45800 \u51216 /\u50864 \u47140 \u49324 \u54637 \u51012  \u49556 \u51649 \u54616 \u44172  \u49436 \u49696 \
   - \uc0\u54861 \u48372 \u44544  \u50500 \u45772  \u49892 \u51228  \u44396 \u47588  \u44256 \u48124 \u44544 \u52376 \u47100  \u44512 \u54805  \u51105 \u55180  \u49884 \u44033  \u50976 \u51648 \
\
7. \uc0\u44208 \u47200  \u49465 \u49496  \'97 \u49548 \u51228 \u47785 : "\u44536 \u47000 \u49436  \u49332  \u47564 \u54620  \u51228 \u54408 \u51068 \u44620 ?"\
   - \uc0\u51593 \u49884  \u44396 \u47588  \u44208 \u47200  X \u8594  "\u54620 \u46160  \u45804  \u45908  \u50024 \u48376  \u54980 \u44592  \u48372 \u44256  \u44208 \u51221 \u54624  \u49373 \u44033 " \u54032 \u45800  \u50976 \u48372 \u47196  \u47560 \u47924 \u47532 \
   - \uc0\u45843 \u44544 \'b7\u44277 \u44048  \u50976 \u46020  \u47704 \u53944 \u47196  \u45149 \u47610 \u44592 \
